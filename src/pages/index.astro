---
import Layout from '../layouts/Layout.astro';

// Información del servidor (simulada para la página estática)
const serverInfo = {
	ip: "192.168.1.100",
	timestamp: new Date().toLocaleString('es-ES', {
		timeZone: 'Europe/Madrid',
		year: 'numeric',
		month: 'long',
		day: 'numeric',
		hour: '2-digit',
		minute: '2-digit',
		second: '2-digit'
	}),
	serverName: "alibaba-cloud-server-01",
	region: "eu-central-1"
};
---

<Layout>
	<main class="main-container" id="main-content">
		<!-- Header con navegación -->
		<header class="header fade-in">
			<nav class="nav container">
				<div class="nav-brand">
					<svg width="40" height="40" viewBox="0 0 100 100" class="logo" role="img" aria-label="Logo Alibaba Cloud">
						<circle cx="50" cy="50" r="45" fill="var(--alibaba-orange)" opacity="0.1"/>
						<circle cx="50" cy="50" r="35" fill="var(--alibaba-orange)" opacity="0.3"/>
						<circle cx="50" cy="50" r="25" fill="var(--alibaba-orange)"/>
						<text x="50" y="58" font-family="Inter" font-weight="bold" font-size="20" fill="white" text-anchor="middle">AC</text>
					</svg>
					<span class="brand-text">Alibaba Cloud</span>
				</div>
				<div class="nav-menu" id="navMenu">
					<a href="#home" class="nav-link">Inicio</a>
					<a href="#info" class="nav-link">Información</a>
					<a href="#contact" class="nav-link">Contacto</a>
				</div>
				<button class="nav-toggle" id="navToggle" aria-label="Abrir menú de navegación" aria-expanded="false" aria-controls="navMenu">
					<span></span>
					<span></span>
					<span></span>
				</button>
			</nav>
		</header>

		<!-- Sección Hero Principal -->
		<section id="home" class="hero">
			<div class="container">
				<div class="hero-content fade-in">
					<!-- Mensaje principal con efecto typing -->
					<h1 class="hero-title">
						<span class="typing-text" id="typingText">Hello Alibaba Cloud</span>
						<span class="cursor" aria-hidden="true">|</span>
					</h1>

					<!-- Subtítulo -->
					<p class="hero-subtitle fade-in">
						Web Server Testing Page
					</p>

					<!-- Descripción -->
					<p class="hero-description fade-in">
						Bienvenido a nuestra página de prueba del servidor web.
						Esta aplicación está optimizada para la nube de Alibaba Cloud,
						ofreciendo rendimiento y escalabilidad excepcionales.
					</p>

					<!-- Botones de acción -->
					<div class="hero-actions fade-in">
						<a href="#info" class="btn btn-primary">
							Ver Información del Servidor
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
								<path d="M7 13l3 3 7-7"/>
							</svg>
						</a>
						<a href="#contact" class="btn btn-secondary">
							Contactar
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
								<path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
							</svg>
						</a>
					</div>
				</div>

				<!-- Elemento decorativo flotante -->
				<div class="floating-elements">
					<div class="floating-card" style="--delay: 0s">
						<svg width="24" height="24" fill="var(--alibaba-orange)" aria-hidden="true">
							<circle cx="12" cy="12" r="10"/>
						</svg>
					</div>
					<div class="floating-card" style="--delay: 1s">
						<svg width="24" height="24" fill="var(--alibaba-blue)" aria-hidden="true">
							<rect x="2" y="2" width="20" height="20" rx="4"/>
						</svg>
					</div>
					<div class="floating-card" style="--delay: 2s">
						<svg width="24" height="24" fill="var(--alibaba-orange-light)" aria-hidden="true">
							<polygon points="12,2 22,20 2,20"/>
						</svg>
					</div>
				</div>
			</div>
		</section>

		<!-- Sección de Información del Servidor -->
		<section id="info" class="server-info">
			<div class="container">
				<h2 class="section-title">Información del Servidor</h2>
				<div class="info-grid">
					<div class="info-card animate-on-scroll">
						<div class="info-icon">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--alibaba-blue)" stroke-width="2" aria-hidden="true">
								<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
								<line x1="8" y1="21" x2="16" y2="21"/>
								<line x1="12" y1="17" x2="12" y2="21"/>
							</svg>
						</div>
						<h3>Dirección IP</h3>
						<p>{serverInfo.ip}</p>
					</div>

					<div class="info-card animate-on-scroll">
						<div class="info-icon">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--alibaba-orange)" stroke-width="2" aria-hidden="true">
								<circle cx="12" cy="12" r="10"/>
								<polyline points="12,6 12,12 16,14"/>
							</svg>
						</div>
						<h3>Timestamp</h3>
						<p id="currentTime">{serverInfo.timestamp}</p>
					</div>

					<div class="info-card animate-on-scroll">
						<div class="info-icon">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--alibaba-blue-light)" stroke-width="2" aria-hidden="true">
								<path d="M2 16.1A5 5 0 015.1 13H9a5 5 0 014.9 3.1l.1.9a5 5 0 004.9 3.1H23a5 5 0 00-5-5H14a5 5 0 00-4.9-3.1l-.1-.9A5 5 0 004.1 8H0a5 5 0 005 5h4.9z"/>
							</svg>
						</div>
						<h3>Servidor</h3>
						<p>{serverInfo.serverName}</p>
					</div>

					<div class="info-card animate-on-scroll">
						<div class="info-icon">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--alibaba-orange-light)" stroke-width="2" aria-hidden="true">
								<circle cx="12" cy="12" r="10"/>
								<path d="M2 12h20"/>
								<path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
							</svg>
						</div>
						<h3>Región</h3>
						<p>{serverInfo.region}</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Sección de Contacto -->
		<section id="contact" class="contact">
			<div class="container">
				<h2 class="section-title">Contacto</h2>
				<div class="contact-content">
					<div class="contact-info animate-on-scroll">
						<h3>¿Necesitas ayuda?</h3>
						<p>Estamos aquí para asistirte con cualquier consulta sobre nuestros servicios en la nube.</p>
						<div class="contact-methods">
							<div class="contact-method">
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--alibaba-orange)" stroke-width="2" aria-hidden="true">
									<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
									<polyline points="22,6 12,13 2,6"/>
								</svg>
								<span>support@alibabacloud.com</span>
							</div>
							<div class="contact-method">
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--alibaba-blue)" stroke-width="2" aria-hidden="true">
									<path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
								</svg>
								<span>+34 900 123 456</span>
							</div>
						</div>
					</div>

					<form class="contact-form animate-on-scroll" id="contactForm">
						<div class="form-group">
							<label for="name" class="visually-hidden">Nombre completo</label>
							<input type="text" id="name" name="name" placeholder="Nombre completo" required autocomplete="name">
						</div>
						<div class="form-group">
							<label for="email" class="visually-hidden">Correo electrónico</label>
							<input type="email" id="email" name="email" placeholder="Correo electrónico" required autocomplete="email">
						</div>
						<div class="form-group">
							<label for="subject" class="visually-hidden">Tema de consulta</label>
							<select id="subject" name="subject" required>
								<option value="">Selecciona un tema</option>
								<option value="support">Soporte técnico</option>
								<option value="sales">Consulta de ventas</option>
								<option value="general">Consulta general</option>
							</select>
						</div>
						<div class="form-group">
							<label for="message" class="visually-hidden">Tu mensaje</label>
							<textarea id="message" name="message" placeholder="Tu mensaje" rows="5" required></textarea>
						</div>
						<button type="submit" class="btn btn-primary btn-full">
							Enviar Mensaje
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
								<line x1="22" y1="2" x2="11" y2="13"/>
								<polygon points="22,2 15,22 11,13 2,9 22,2"/>
							</svg>
						</button>
					</form>
				</div>
			</div>
		</section>

		<!-- Footer -->
		<footer class="footer">
			<div class="container">
				<div class="footer-content">
					<div class="footer-brand">
						<svg width="32" height="32" viewBox="0 0 100 100" class="footer-logo" role="img" aria-label="Logo Alibaba Cloud">
							<circle cx="50" cy="50" r="45" fill="var(--alibaba-orange)" opacity="0.1"/>
							<circle cx="50" cy="50" r="35" fill="var(--alibaba-orange)" opacity="0.3"/>
							<circle cx="50" cy="50" r="25" fill="var(--alibaba-orange)"/>
							<text x="50" y="58" font-family="Inter" font-weight="bold" font-size="16" fill="white" text-anchor="middle">AC</text>
						</svg>
						<span>Alibaba Cloud © {new Date().getFullYear()}</span>
					</div>
					<div class="footer-links">
						<a href="#privacy" class="footer-link">Política de Privacidad</a>
						<a href="#terms" class="footer-link">Términos de Servicio</a>
						<a href="#contact" class="footer-link">Contacto</a>
					</div>
				</div>
			</div>
		</footer>
	</main>
</Layout>

<style>
	/* ====== LAYOUT PRINCIPAL ====== */
	.main-container {
		min-height: 100vh;
		position: relative;
		z-index: 1;
	}

	/* ====== VISUALLY HIDDEN (ACCESIBILIDAD) ====== */
	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	/* ====== SPINNER ANIMATION ====== */
	@keyframes spin {
		to { transform: rotate(360deg); }
	}
	.animate-spin {
		animation: spin 1s linear infinite;
	}

	/* ====== HEADER Y NAVEGACIÓN ====== */
	.header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 1000;
		background: rgba(15, 20, 25, 0.95);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		animation-delay: 0.2s;
	}

	.nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem 0;
		position: relative;
	}

	.nav-brand {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-weight: 600;
		font-size: 1.25rem;
		color: var(--alibaba-orange);
	}

	.logo {
		transition: transform 0.3s ease;
	}

	.logo:hover {
		transform: rotate(360deg);
	}

	.nav-menu {
		display: flex;
		gap: 2rem;
		align-items: center;
	}

	.nav-link {
		color: rgba(255, 255, 255, 0.8);
		text-decoration: none;
		font-weight: 500;
		position: relative;
		transition: color 0.3s ease;
	}

	.nav-link:hover {
		color: var(--alibaba-orange);
	}

	.nav-link::after {
		content: '';
		position: absolute;
		bottom: -4px;
		left: 0;
		width: 0;
		height: 2px;
		background: var(--alibaba-orange);
		transition: width 0.3s ease;
	}

	.nav-link:hover::after {
		width: 100%;
	}

	.nav-toggle {
		display: none;
		flex-direction: column;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5rem;
		gap: 3px;
	}

	.nav-toggle span {
		width: 25px;
		height: 3px;
		background: var(--alibaba-orange);
		transition: all 0.3s ease;
		border-radius: 2px;
	}

	/* ====== SECCIÓN HERO ====== */
	.hero {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		padding: 6rem 0 4rem;
		text-align: center;
	}

	.hero-content {
		max-width: 800px;
		animation-delay: 0.5s;
	}

	.hero-title {
		font-size: clamp(2.5rem, 8vw, 4.5rem);
		font-weight: 700;
		margin-bottom: 1.5rem;
		background: linear-gradient(135deg, var(--alibaba-orange) 0%, var(--alibaba-blue) 100%);
		background-clip: text;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		line-height: 1.2;
	}

	.typing-text {
		display: inline-block;
	}

	.cursor {
		display: inline-block;
		animation: blink 1s infinite;
		color: var(--alibaba-orange);
	}

	@keyframes blink {
		0%, 50% { opacity: 1; }
		51%, 100% { opacity: 0; }
	}

	.hero-subtitle {
		font-size: 1.5rem;
		color: var(--alibaba-blue-light);
		margin-bottom: 1.5rem;
		font-weight: 400;
		animation-delay: 1s;
	}

	.hero-description {
		font-size: 1.125rem;
		color: rgba(255, 255, 255, 0.8);
		margin-bottom: 3rem;
		line-height: 1.7;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
		animation-delay: 1.5s;
	}

	.hero-actions {
		display: flex;
		gap: 1.5rem;
		justify-content: center;
		flex-wrap: wrap;
		animation-delay: 2s;
	}

	/* ====== ELEMENTOS FLOTANTES ====== */
	.floating-elements {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: -1;
	}

	.floating-card {
		position: absolute;
		width: 60px;
		height: 60px;
		background: rgba(255, 255, 255, 0.05);
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		backdrop-filter: blur(10px);
		border: 1px solid rgba(255, 255, 255, 0.1);
		animation: float 6s ease-in-out infinite;
		animation-delay: var(--delay);
	}

	.floating-card:nth-child(1) {
		top: 20%;
		left: 15%;
	}

	.floating-card:nth-child(2) {
		top: 60%;
		right: 15%;
	}

	.floating-card:nth-child(3) {
		bottom: 30%;
		left: 10%;
	}

	@keyframes float {
		0%, 100% {
			transform: translateY(0px) rotate(0deg);
		}
		50% {
			transform: translateY(-20px) rotate(180deg);
		}
	}

	/* ====== BOTONES ====== */
	.btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 1rem 2rem;
		border: none;
		border-radius: 12px;
		font-size: 1rem;
		font-weight: 600;
		text-decoration: none;
		cursor: pointer;
		transition: all 0.3s ease;
		position: relative;
		overflow: hidden;
		background: none;
	}

	.btn::before {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
		transition: left 0.5s ease;
	}

	.btn:hover::before {
		left: 100%;
	}

	.btn-primary {
		background: linear-gradient(135deg, var(--alibaba-orange) 0%, var(--alibaba-orange-dark) 100%);
		color: white;
		box-shadow: var(--shadow-lg);
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-xl);
		background: linear-gradient(135deg, var(--alibaba-orange-light) 0%, var(--alibaba-orange) 100%);
	}

	.btn-secondary {
		background: rgba(24, 144, 255, 0.1);
		border: 2px solid var(--alibaba-blue);
		color: var(--alibaba-blue-light);
	}

	.btn-secondary:hover {
		background: var(--alibaba-blue);
		color: white;
		transform: translateY(-2px);
	}

	.btn-full {
		width: 100%;
		justify-content: center;
	}

	/* ====== SECCIONES ====== */
	section[id] {
		scroll-margin-top: 5rem;
	}

	.server-info, .contact {
		padding: 6rem 0;
		position: relative;
	}

	.section-title {
		font-size: 2.5rem;
		font-weight: 700;
		text-align: center;
		margin-bottom: 4rem;
		background: linear-gradient(135deg, var(--alibaba-orange) 0%, var(--alibaba-blue) 100%);
		background-clip: text;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	/* ====== GRID DE INFORMACIÓN ====== */
	.info-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 2rem;
		max-width: 1000px;
		margin: 0 auto;
	}

	.info-card {
		background: rgba(255, 255, 255, 0.05);
		padding: 2rem;
		border-radius: 16px;
		text-align: center;
		border: 1px solid rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(10px);
		transition: all 0.3s ease;
		position: relative;
		overflow: hidden;
	}

	.info-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 4px;
		background: linear-gradient(90deg, var(--alibaba-orange), var(--alibaba-blue));
		transform: scaleX(0);
		transition: transform 0.3s ease;
	}

	.info-card:hover {
		transform: translateY(-8px) scale(1.02);
		box-shadow: var(--shadow-xl);
		border-color: var(--alibaba-orange);
	}

	.info-card:hover::before {
		transform: scaleX(1);
	}

	.info-icon {
		margin-bottom: 1.5rem;
		display: flex;
		justify-content: center;
	}

	.info-card h3 {
		font-size: 1.25rem;
		font-weight: 600;
		margin-bottom: 0.75rem;
		color: var(--alibaba-orange-light);
	}

	.info-card p {
		color: rgba(255, 255, 255, 0.8);
		font-size: 1rem;
		font-weight: 500;
	}

	/* ====== SECCIÓN DE CONTACTO ====== */
	.contact-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		max-width: 1000px;
		margin: 0 auto;
		align-items: start;
	}

	.contact-info h3 {
		font-size: 1.75rem;
		font-weight: 600;
		margin-bottom: 1rem;
		color: var(--alibaba-orange-light);
	}

	.contact-info p {
		color: rgba(255, 255, 255, 0.8);
		margin-bottom: 2rem;
		line-height: 1.7;
	}

	.contact-methods {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.contact-method {
		display: flex;
		align-items: center;
		gap: 1rem;
		color: rgba(255, 255, 255, 0.9);
		font-weight: 500;
	}

	/* ====== FORMULARIO ====== */
	.contact-form {
		background: rgba(255, 255, 255, 0.05);
		padding: 2.5rem;
		border-radius: 16px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(10px);
	}

	.form-group {
		margin-bottom: 1.5rem;
	}

	.form-group input,
	.form-group select,
	.form-group textarea {
		width: 100%;
		padding: 1rem;
		background: rgba(255, 255, 255, 0.05);
		border: 2px solid rgba(255, 255, 255, 0.1);
		border-radius: 8px;
		color: white;
		font-size: 1rem;
		transition: all 0.3s ease;
		font-family: inherit;
	}

	.form-group input:focus,
	.form-group select:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: var(--alibaba-orange);
		background: rgba(255, 255, 255, 0.08);
		box-shadow: 0 0 0 3px rgba(255, 106, 0, 0.1);
	}

	.form-group input::placeholder,
	.form-group textarea::placeholder {
		color: rgba(255, 255, 255, 0.65);
	}

	.form-group option {
		background: var(--neutral-800);
		color: white;
	}

	/* ====== FOOTER ====== */
	.footer {
		background: rgba(15, 20, 25, 0.8);
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		padding: 2rem 0;
		margin-top: 4rem;
	}

	.footer-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.footer-brand {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		color: rgba(255, 255, 255, 0.8);
		font-weight: 500;
	}

	.footer-links {
		display: flex;
		gap: 2rem;
	}

	.footer-link {
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
		transition: color 0.3s ease;
	}

	.footer-link:hover {
		color: var(--alibaba-orange);
	}

	/* ====== ANIMACIONES DE SCROLL ====== */
	.animate-on-scroll {
		opacity: 0;
		transform: translateY(30px);
	}

	.animate-on-scroll.is-visible {
		opacity: 1;
		transform: translateY(0);
		transition: opacity 0.6s ease, transform 0.6s ease;
	}

	/* ====== RESPONSIVE DESIGN ====== */
	@media (max-width: 768px) {
		.nav-menu {
			position: fixed;
			top: 100%;
			left: 0;
			right: 0;
			background: rgba(15, 20, 25, 0.98);
			backdrop-filter: blur(10px);
			flex-direction: column;
			padding: 2rem;
			gap: 1.5rem;
			transform: translateY(-100%);
			opacity: 0;
			visibility: hidden;
			transition: all 0.3s ease;
		}

		.nav-menu.active {
			transform: translateY(0);
			opacity: 1;
			visibility: visible;
		}

		.nav-toggle {
			display: flex;
		}

		.nav-toggle.active span:nth-child(1) {
			transform: rotate(45deg) translate(6px, 6px);
		}

		.nav-toggle.active span:nth-child(2) {
			opacity: 0;
		}

		.nav-toggle.active span:nth-child(3) {
			transform: rotate(-45deg) translate(6px, -6px);
		}

		.hero-actions {
			flex-direction: column;
			align-items: center;
		}

		.contact-content {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.footer-content {
			flex-direction: column;
			text-align: center;
		}

		.floating-card {
			display: none;
		}
	}

	@media (max-width: 480px) {
		.hero {
			padding: 4rem 0 2rem;
		}

		.section-title {
			font-size: 2rem;
		}

		.info-grid {
			grid-template-columns: 1fr;
		}

		.contact-form {
			padding: 1.5rem;
		}
	}
</style>

<script>
	// ====== EFECTO DE TYPING ======
	const typingText = document.getElementById('typingText') as HTMLElement;
	const text = 'Hello Alibaba Cloud';
	let index = 0;

	function typeWriter() {
		if (index < text.length && typingText) {
			typingText.textContent += text.charAt(index);
			index++;
			setTimeout(typeWriter, 150);
		}
	}

	// ====== NAVEGACIÓN MÓVIL ======
	const navToggle = document.getElementById('navToggle');
	const navMenu = document.getElementById('navMenu');

	navToggle?.addEventListener('click', () => {
		navMenu?.classList.toggle('active');
		navToggle.classList.toggle('active');
		const isExpanded = navToggle.getAttribute('aria-expanded') === 'true';
		navToggle.setAttribute('aria-expanded', String(!isExpanded));
	});

	// Cerrar menú al hacer click en un enlace
	document.querySelectorAll('.nav-link').forEach(link => {
		link.addEventListener('click', () => {
			navMenu?.classList.remove('active');
			navToggle?.classList.remove('active');
			navToggle?.setAttribute('aria-expanded', 'false');
		});
	});

	// ====== ACTUALIZAR TIMESTAMP ======
	function updateTimestamp() {
		const now = new Date();
		const timeString = now.toLocaleString('es-ES', {
			timeZone: 'Europe/Madrid',
			year: 'numeric',
			month: 'long',
			day: 'numeric',
			hour: '2-digit',
			minute: '2-digit',
			second: '2-digit'
		});
		const timeElement = document.getElementById('currentTime');
		if (timeElement) {
			timeElement.textContent = timeString;
		}
	}

	// ====== ANIMACIONES DE SCROLL ======
	const observerOptions = {
		threshold: 0.1,
		rootMargin: '0px 0px -50px 0px'
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add('is-visible');
				observer.unobserve(entry.target);
			}
		});
	}, observerOptions);

	// ====== FORMULARIO DE CONTACTO ======
	const contactForm = document.getElementById('contactForm') as HTMLFormElement;
	contactForm?.addEventListener('submit', (e) => {
		e.preventDefault();

		// Simular envío del formulario
		const submitBtn = contactForm.querySelector('button[type="submit"]') as HTMLButtonElement;
		if (submitBtn) {
			const originalText = submitBtn.innerHTML;

			submitBtn.innerHTML = `
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="animate-spin">
					<circle cx="12" cy="12" r="10"/>
					<path d="M12 6V2"/>
				</svg>
				Enviando...
			`;
			submitBtn.disabled = true;

			setTimeout(() => {
				if (submitBtn) {
					submitBtn.innerHTML = `
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M20 6L9 17l-5-5"/>
						</svg>
						¡Enviado!
					`;

					setTimeout(() => {
						if (submitBtn) {
							submitBtn.innerHTML = originalText;
							submitBtn.disabled = false;
							contactForm.reset();
						}
					}, 2000);
				}
			}, 1500);
		}
	});

	// ====== INICIALIZACIÓN ======
	document.addEventListener('DOMContentLoaded', () => {
		// Limpiar texto para efecto typing
		if (typingText) typingText.textContent = '';

		// Iniciar efecto de typing
		setTimeout(typeWriter, 1000);

		// Actualizar timestamp cada segundo
		updateTimestamp();
		setInterval(updateTimestamp, 1000);

		// Configurar observer para animaciones de scroll
		document.querySelectorAll('.animate-on-scroll').forEach(el => {
			observer.observe(el);
		});
	});
</script>
